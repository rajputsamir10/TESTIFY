# Django runtime
DJANGO_ENV=production
DEBUG=False
SECRET_KEY=replace-with-strong-secret

# Host and cross-origin settings
ALLOWED_HOSTS=<backend-app>.azurewebsites.net
CORS_ALLOWED_ORIGINS=https://<frontend-app>.azurestaticapps.net
CSRF_TRUSTED_ORIGINS=https://<frontend-app>.azurestaticapps.net,https://<backend-app>.azurewebsites.net

# Cookie/auth settings for cross-site frontend/backend domains
AUTH_COOKIE_SECURE=True
AUTH_COOKIE_SAMESITE=None
AUTH_COOKIE_DOMAIN=

# Database
DATABASE_URL=postgres://<user>:<password>@<host>:5432/<database>
DB_SSLMODE=require
DB_CONN_MAX_AGE=0

# Security
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True
USE_X_FORWARDED_HOST=True
SECURE_PROXY_SSL_HEADER_ENABLED=True

# Email (OTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_TIMEOUT=10
EMAIL_HOST_USER=<smtp-user>
EMAIL_HOST_PASSWORD=<smtp-password-or-app-password>
DEFAULT_FROM_EMAIL=Testify <noreply@testify.com>

# Compiler integration
ONLINECOMPILER_API_URL=https://api.onlinecompiler.io
ONLINECOMPILER_API_KEY=<api-key>

TIME_ZONE=UTC
